                <a href="https://www.sslshopper.com/ssl-checker.html#hostname={{ section.settings.selo1 }}">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0655/0696/7773/files/NORTON_RBANCO.png?v=1675262979"
                    alt="Norton Secured"
                    style="width: 277px; height:36px; "
                    loading="lazy"
                  >
                </a>
                <a href="https://www.reclameaqui.com.br/{{ section.settings.selo2 }}">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0655/0696/7773/files/RECLAMEAQUI_RBANCO.png?v=1675262979"
                    alt="Reclame Aqui"
                    style="width: 250px; height:20px;"
                    loading="lazy"
                  >
                </a>
                <a href="https://transparencyreport.google.com/safe-browsing/search?url={{ section.settings.selo3 }}">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0655/0696/7773/files/GOOGLE_BRANCO.png?v=1675262980"
                    alt="Google Seguro"
