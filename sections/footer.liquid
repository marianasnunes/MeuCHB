                    style="width: 250px; height:20px;"
                    loading="lazy"
                  >
                </a>
                  <a href="https://transparencyreport.google.com/safe-browsing/search?url={{ section.settings.selo3 }}">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0706/7467/7999/files/GOOGLE_3d6435b4-bb6b-4d5f-991b-076bf9440d60.png?v=1720012327"
                    alt="Google Seguro"
                    style="width: 277px; height:36px;"
                    loading="lazy"
