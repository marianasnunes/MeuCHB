        </div>
      {% endif %}
      {%- if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
        <div class="footer__payment-methods footer_section" style="width: ;">
          <div class="v-stack gap-2">
            <span class="text-x">{{ 'cart.general.we_accept' | t }}</span>

            <div class="h-stack gap-2 wrap justify-center we-accept">
              {% assign payment_mode = settings.payment_mode %}
              

{% if payment_mode == 'external' %}
