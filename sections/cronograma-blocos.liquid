<style>
  .custom-three-blocks-{{ section.id }} {
    display: flex;
    flex-wrap: nowrap;
    gap: 20px; /* Espaçamento entre os blocos */
    padding: 40px 20px;
    max-width: 1300px;
    margin: 0 auto;
    align-items: stretch; /* Faz com que todos os blocos tenham a mesma altura */
  }

  .block-item-{{ section.id }} {
    flex: 1;
    width: 33.333%;
    position: relative;
    overflow: hidden;
    border-radius: 24px; /* Bordas arredondadas conforme a imagem */
    display: flex;
    flex-direction: column;
  }

  /* Estilos para a Imagem e Vídeo */
  .block-item-{{ section.id }}.media-block img,
  .block-item-{{ section.id }}.media-block video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 500px; /* Altura mínima para manter o formato */
  }

  /* Estilos para o Bloco de Texto (Meio) */
  .block-item-{{ section.id }}.text-block {
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 40px;
  }

  .text-block-subheading-{{ section.id }} {
    font-size: 16px;
    margin-bottom: 20px;
    color: #4A3C31;
  }

  .text-block-heading-{{ section.id }} {
    font-size: 32px;
    line-height: 1.2;
    margin-bottom: 30px;
    color: #3A2A20;
    font-family: serif; /* Ajuste para a fonte do seu tema se necessário */
  }

  .text-block-content-{{ section.id }} {
    font-size: 14px;
    line-height: 1.6;
    color: #665D55;
    margin-bottom: 40px;
  }

  .text-block-content-{{ section.id }} p {
    margin-bottom: 15px;
  }

  .text-block-btn-{{ section.id }} {
    display: inline-block;
    padding: 14px 28px;
    border: 1px solid #4A3C31;
    color: #4A3C31;
    border-radius: 50px; /* Botão em formato de pílula */
    text-decoration: none;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .text-block-btn-{{ section.id }}:hover {
    background-color: #4A3C31;
    color: #ffffff;
  }

  /* Responsividade para Celular */
  @media (max-width: 850px) {
    .custom-three-blocks-{{ section.id }} {
      flex-direction: column;
      padding: 20px 15px;
      gap: 15px;
    }
    
    .block-item-{{ section.id }} {
      width: 100%;
    }

    .block-item-{{ section.id }}.media-block img,
    .block-item-{{ section.id }}.media-block video {
      min-height: 400px;
    }
    
    .text-block-heading-{{ section.id }} {
      font-size: 26px;
    }
  }
</style>

<div class="custom-three-blocks-{{ section.id }}">
  
  <div class="block-item-{{ section.id }} media-block">
    {% if section.settings.image_1 != blank %}
      {{ section.settings.image_1 | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.image_1.alt }}
    {% else %}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>

  <div class="block-item-{{ section.id }} text-block" style="background-color: {{ section.settings.bg_color }};">
    
    {% if section.settings.subheading != blank %}
      <div class="text-block-subheading-{{ section.id }}">
        {{ section.settings.subheading }}
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="text-block-heading-{{ section.id }}">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="text-block-content-{{ section.id }}">
        {{ section.settings.text }}
      </div>
    {% endif %}

    {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
      <a href="{{ section.settings.btn_link }}" class="text-block-btn-{{ section.id }}">
        {{ section.settings.btn_text }}
      </a>
    {% endif %}

  </div>

  <div class="block-item-{{ section.id }} media-block">
    {% if section.settings.video_3 != blank %}
      {{ section.settings.video_3 | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>

</div>

{% schema %}
{
  "name": "Cronograma (3 Blocos)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Bloco 1 (Esquerda)"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Imagem da esquerda"
    },
    {
      "type": "header",
      "content": "Bloco 2 (Meio - Texto)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo",
      "default": "#FFF6EE"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo (com emoji)",
      "default": "👋 Olá, somos"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Título Principal",
      "default": "O cronograma que recupera fios de verdade"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto Descritivo",
      "default": "<p>Mais do que promessa: ciência aplicada com estratégia.</p>"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texto do Botão",
      "default": "CONHEÇA O CRONOGRAMA"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Link do Botão"
    },
    {
      "type": "header",
      "content": "Bloco 3 (Direita - Vídeo)"
    },
    {
      "type": "video",
      "id": "video_3",
      "label": "Vídeo (Autoplay)",
      "info": "Para funcionar em autoplay, o vídeo será mudo."
    }
  ],
  "presets": [
    {
      "name": "Cronograma (3 Blocos)",
      "category": "Custom"
    }
  ]
}
{% endschema %}