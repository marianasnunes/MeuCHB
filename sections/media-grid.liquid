{%- render 'section-spacing-collapsing' -%}
<style>
  #shopify-section-{{ section.id }} {
    --media-grid-row-height: {{ section.settings.mobile_row_height }}px;
  }
  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --media-grid-row-height: {{ section.settings.desktop_row_height }}px;
    }
  }

  /* --- ESTILOS DA CAIXINHA FIGMA (DESKTOP) --- */
  .figma-card-wrapper-{{ section.id }} .figma-subheading {
    display: block; font-size: 16px; font-weight: 400; margin-bottom: -5px; line-height: 1;
  }
  .figma-card-wrapper-{{ section.id }} .figma-title {
    font-family: 'Magnat Head', 'Magnat', sans-serif !important; font-weight: 600 !important; margin: 0 0 10px 0; line-height: 1.1;
  }
  .figma-card-wrapper-{{ section.id }} .figma-desc {
    font-size: 14px; line-height: 1.5; margin-top: 10px;
  }
  .figma-card-wrapper-{{ section.id }} .has-bg {
    padding: 24px; border-radius: 16px;
  }

  /* --- ESTILOS DA CAIXINHA FIGMA (CELULAR / MOBILE) --- */
  @media screen and (max-width: 767px) {
    .figma-card-wrapper-{{ section.id }} .figma-subheading {
      font-size: 12px !important; margin-bottom: -2px;
    }
    .figma-card-wrapper-{{ section.id }} .figma-title {
      font-size: 20px !important; margin-bottom: 6px !important;
    }
    .figma-card-wrapper-{{ section.id }} .figma-desc {
      font-size: 12px !important; margin-top: 6px !important;
    }
    .figma-card-wrapper-{{ section.id }} .has-bg {
      padding: 16px; border-radius: 12px;
    }
  }

  {%- for block in section.blocks -%}
    #media-grid-{{ block.id }} {
      --content-over-media-overlay: {{ block.settings.overlay_color.rgb }} /{{ block.settings.overlay_opacity | divided_by: 100.0 }};
      {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
        --content-over-media-gap: 1rem;
      {%- endif -%}
    }
    {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
      @media screen and (min-width: 740px) {
        #media-grid-{{ block.id }} {
          --content-over-media-gap: 1.5rem;
        }
      }
    {%- endif -%}
  {%- endfor -%}
</style>
<div {% render 'section-properties', narrow: section.settings.reduce_width %}>
  <media-grid class="media-grid">
    {%- for block in section.blocks -%}
      
      {%- assign is_first_block = forloop.first -%}
      
      <a
        {% if block.settings.link_url != blank %}
          href="{{ block.settings.link_url }}"
        {% endif %}
        class="media-grid__item shadow group"
        reveal-js
        style="--media-grid-column-span: {{ block.settings.desktop_column_span }}; --media-grid-row-span: {{ block.settings.desktop_row_span }}; cursor: pointer;"
        {{ block.shopify_attributes }}
      >
        {%- capture style -%}
          --content-over-media-overlay: {{ block.settings.overlay_color.rgb }} / {{ block.settings.overlay_opacity | divided_by: 100.0 }};
          {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
            --content-over-media-gap: 1.5rem;
          {%- endif -%}
        {%- endcapture -%}
        <div
          id="media-grid-{{ block.id }}"
          {% render 'surface',
            class: 'content-over-media rounded',
            background: block.settings.background,
            background_gradient: block.settings.background_gradient,
            text_color: block.settings.text_color
          %}
        >
          {%- case block.type -%}
            {%- when 'image' -%}
              {%- if block.settings.image -%}
                {%- capture sizes -%}(max-width: 699px) 100vw, min({{ 390 | times: block.settings.desktop_column_span }}px, {{ 25 | times: block.settings.desktop_column_span }}vw){%- endcapture -%}
                {{-
                  block.settings.image
                  | image_url: width: block.settings.image.width
                  | image_tag:
                    loading: 'lazy',
                    sizes: sizes,
                    widths: '200,300,400,500,600,700,800,1000,1200,1400,1600,1800,2000,2200,2400',
                    class: 'content-over-media__media zoom-image'
                -}}
              {%- endif -%}
            {%- when 'video' -%}
              {%- if block.settings.video -%}
                <video-media autoplay style="--aspect-ratio: auto">
                  {%- if block.settings.show_video_controls -%}
                    {%- assign loop_video = false -%}
                  {%- else -%}
                    {%- assign loop_video = true -%}
                  {%- endif -%}
                  {{-
                    block.settings.video
                    | video_tag:
                      playsinline: true,
                      muted: true,
                      loop: loop_video,
                      controls: block.settings.show_video_controls,
                      preload: 'metadata',
                      class: 'object-fill'
                  -}}
                </video-media>
              {%- else -%}
                <video-media host="{{ block.settings.external_video_url.type }}" autoplay style="--aspect-ratio: auto">
                  <template>
                    {%- if block.settings.external_video_url.type == 'youtube' -%}
                      <iframe
                        src="https://www.youtube.com/embed/{{ block.settings.external_video_url.id }}?playsinline=1&autoplay=1&controls=0&mute=1&loop=1&playlist={{ block.settings.external_video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}"
                        allow="autoplay; encrypted-media"
                        allowfullscreen="allowfullscreen"
                      ></iframe>
                    {%- elsif block.settings.external_video_url.type == 'vimeo' -%}
                      <iframe
                        src="https://player.vimeo.com/video/{{ block.settings.external_video_url.id }}?autoplay=1&autopause=1&background=1&loop=1&muted=1&transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.text_color | remove_first: '#' }}"
                        allow="autoplay; encrypted-media;"
                        allowfullscreen="allowfullscreen"
                      ></iframe>
                    {%- endif -%}
                  </template>
                </video-media>
              {%- endif -%}
          {%- endcase -%}
          
          {%- if block.settings.title != blank or block.settings.subheading != blank or block.settings.description != blank -%}
            
            {%- assign apply_bg = false -%}
            {%- if is_first_block and block.settings.box_bg != 'rgba(0,0,0,0)' and block.settings.box_bg != blank -%}
              {%- assign apply_bg = true -%}
            {%- endif -%}

            <div class="{{ block.settings.mobile_text_position }} {{ block.settings.desktop_text_position }} figma-card-wrapper-{{ section.id }}">
              
              <div class="prose {% if apply_bg %}has-bg{% endif %}" style="{% if apply_bg %}background-color: {{ block.settings.box_bg }};{% else %}padding: 0;{% endif %} color: {{ block.settings.box_text }}; text-align: inherit; display: inline-block;">
                
                {%- if block.settings.subheading != blank -%}
                  <span class="figma-subheading">{{ block.settings.subheading }}</span>
                {%- endif -%}

                {%- if block.settings.title != blank -%}
                  <p class="{{ block.settings.heading_tag }} figma-title" style="color: inherit;">
                    {% render 'styled-text', content: block.settings.title, gradient: block.settings.text_gradient %}
                  </p>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <div class="figma-desc" style="color: inherit;">
                    {{ block.settings.description }}
                  </div>
                {%- endif -%}

              </div>
            </div>
          {%- endif -%}

        </div>
      </a>
    {%- endfor -%}
  </media-grid>
</div>
{% schema %}
{
  "name": "Mídias em Destaque",
  "class": "shopify-section--media-grid",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "max_blocks": 15,
  "blocks": [
    {
      "type": "image",
      "name": "Imagem",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem",
          "info": "1000 x 1500px .jpg recomendado (retrato) ou 1500 x 1500px .jpg recomendado (quadrado)"
        },
        {
          "type": "color",
          "id": "box_bg",
          "label": "Fundo da Caixa de Texto",
          "default": "#FAF4EE",
          "info": "IMPORTANTE: O código está travado para que o fundo seja aplicado APENAS ao primeiro bloco (maior). Os outros blocos ignorarão esta cor."
        },
        {
          "type": "color",
          "id": "box_text",
          "label": "Cor do Texto da Caixa",
          "default": "#3A2A20"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subtítulo (Aparece acima do título)",
          "default": "Kit"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título Principal",
          "default": "NUTRIÇÃO"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Texto descritivo",
          "default": "<p><strong>Disciplina e controle do frizz</strong><br>Para fios porosos e desalinhados.</p>"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Tamanho do título",
          "options": [
            {
              "value": "h1",
              "label": "H1"
            },
            {
              "value": "h2",
              "label": "H2"
            },
            {
              "value": "h3",
              "label": "H3"
            },
            {
              "value": "h4",
              "label": "H4"
            },
            {
              "value": "h5",
              "label": "H5"
            },
            {
              "value": "h6",
              "label": "H6"
            }
          ],
          "default": "h3"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "URL do Link",
          "info": "A imagem inteira será clicável e levará para este link."
        },
        {
          "type": "header",
          "content": "Móvel"
        },
        {
          "type": "select",
          "id": "mobile_text_position",
          "label": "Posição do conteúdo",
          "options": [
            {
              "value": "place-self-start text-start",
              "label": "Topo esquerda"
            },
            {
              "value": "place-self-start-center text-center",
              "label": "Topo centro"
            },
            {
              "value": "place-self-start-end text-end",
              "label": "Topo direita"
            },
            {
              "value": "place-self-center-start text-start",
              "label": "Centro esquerda"
            },
            {
              "value": "place-self-center text-center",
              "label": "Centro centro"
            },
            {
              "value": "place-self-center-end text-end",
              "label": "Centro direita"
            },
            {
              "value": "place-self-end-start text-start",
              "label": "Baixo esquerda"
            },
            {
              "value": "place-self-end-center text-center",
              "label": "Baixo centro"
            },
            {
              "value": "place-self-end text-end",
              "label": "Baixo direita"
            }
          ],
          "default": "place-self-center text-center"
        },
        {
          "type": "header",
          "content": "Desktop",
          "info": "Ao usar um bloco 1x1, recomendamos não usar texto sobre a mídia."
        },
        {
          "type": "range",
          "id": "desktop_column_span",
          "label": "Coluna",
          "min": 1,
          "max": 4,
          "default": 2
        },
        {
          "type": "range",
          "id": "desktop_row_span",
          "label": "Linha",
          "min": 1,
          "max": 3,
          "default": 2
        },
        {
          "type": "select",
          "id": "desktop_text_position",
          "label": "Posição do conteúdo",
          "options": [
            {
              "value": "sm:place-self-start sm:text-start",
              "label": "Topo esquerda"
            },
            {
              "value": "sm:place-self-start-center sm:text-center",
              "label": "Topo centro"
            },
            {
              "value": "sm:place-self-start-end sm:text-end",
              "label": "Topo direita"
            },
            {
              "value": "sm:place-self-center-start sm:text-start",
              "label": "Centro esquerda"
            },
            {
              "value": "sm:place-self-center sm:text-center",
              "label": "Centro centro"
            },
            {
              "value": "sm:place-self-center-end sm:text-end",
              "label": "Centro direita"
            },
            {
              "value": "sm:place-self-end-start sm:text-start",
              "label": "Baixo esquerda"
            },
            {
              "value": "sm:place-self-end-center sm:text-center",
              "label": "Baixo centro"
            },
            {
              "value": "sm:place-self-end sm:text-end",
              "label": "Baixo direita"
            }
          ],
          "default": "sm:place-self-center sm:text-center"
        },
        {
          "type": "header",
          "content": "Cores",
          "info": "Gradiente substitui cores sólidas quando configurado. Fundo é ignorado quando imagem é usada."
        },
        {
          "type": "color",
          "id": "background",
          "label": "Fundo",
          "default": "#000000"
        },
        {
          "type": "color_background",
          "id": "background_gradient",
          "label": "Gradiente de fundo"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Texto",
          "default": "#ffffff"
        },
        {
          "type": "color_background",
          "id": "text_gradient",
          "label": "Gradiente do texto"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Sobreposição",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Opacidade da sobreposição",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Largura total",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "reduce_width",
      "label": "Reduzir largura em telas grandes",
      "default": false
    },
    {
      "type": "header",
      "content": "Altura da linha",
      "info": "Defina a altura de uma única linha, a partir da qual a grelha é criada dinamicamente."
    },
    {
      "type": "range",
      "id": "desktop_row_height",
      "label": "Altura da linha no desktop",
      "min": 150,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 290
    },
    {
      "type": "range",
      "id": "mobile_row_height",
      "label": "Altura da linha no móvel",
      "min": 120,
      "max": 260,
      "step": 10,
      "unit": "px",
      "default": 150
    }
  ],
  "presets": [
    {
      "name": "Grelha de Mídia (Customizada)",
      "blocks": [
        {
          "type": "image",
          "settings": {
            "desktop_column_span": 2,
            "desktop_row_span": 1
          }
        },
        {
          "type": "image",
          "settings": {
            "desktop_column_span": 2,
            "desktop_row_span": 2
          }
        },
        {
          "type": "image",
          "settings": {
            "desktop_column_span": 2,
            "desktop_row_span": 1
          }
        }
      ]
    }
  ]
}
{% endschema %}