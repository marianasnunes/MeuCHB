{{ 'quiz-capilar.css' | asset_url | stylesheet_tag }}

<div class="quiz-dc-wrap" id="quiz-dc-{{ section.id }}" data-section-id="{{ section.id }}">

  <header class="quiz-dc-header">
    <div class="quiz-dc-eyebrow">{{ section.settings.eyebrow | default: 'MEUCHB.COM.BR · MÉTODO CH' }}</div>
    <h1 class="quiz-dc-h1">{{ section.settings.heading | default: 'Diagnóstico <em>Capilar</em>' }}</h1>
    <div class="quiz-dc-sub">{{ section.settings.subheading | default: 'Responda 7 perguntas e descubra qual kit foi feito para o seu cabelo.' }}</div>
  </header>

  <main class="quiz-dc-main">

    <!-- INTRO -->
    <div class="quiz-dc-screen quiz-dc-intro" data-screen="intro">
      <div class="quiz-dc-card quiz-dc-card--intro">
        <div class="quiz-dc-eyebrow">Diagnóstico Capilar</div>
        <h2 class="quiz-dc-h2">Qual kit o seu<br>cabelo <em>realmente</em> precisa?</h2>
        <p class="quiz-dc-intro-p">Em menos de 3 minutos, vamos entender o estado atual do seu fio e indicar o kit CH ideal para a sua rotina.</p>
        <div class="quiz-dc-dots"><span></span><span></span><span></span></div>
        <div class="quiz-dc-features">
          <span><i></i>7 perguntas</span>
          <span><i></i>Resultado personalizado</span>
          <span><i></i>Método CH validado</span>
        </div>
        <button type="button" class="quiz-dc-btn quiz-dc-start">Começar Diagnóstico</button>
      </div>
    </div>

    <!-- QUESTION -->
    <div class="quiz-dc-screen quiz-dc-question" data-screen="question" hidden>
      <div class="quiz-dc-qwrap">
        <div class="quiz-dc-progress-row">
          <span class="quiz-dc-qlabel-sm"></span>
          <span class="quiz-dc-percent"></span>
        </div>
        <div class="quiz-dc-progress-track">
          <div class="quiz-dc-progress-fill"></div>
        </div>
        <div class="quiz-dc-card">
          <div class="quiz-dc-eyebrow quiz-dc-qlabel"></div>
          <h3 class="quiz-dc-qtitle"></h3>
          <p class="quiz-dc-qhelp"></p>
          <div class="quiz-dc-options"></div>
          <div class="quiz-dc-actions">
            <button type="button" class="quiz-dc-btn quiz-dc-continue" disabled>Continuar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- RESULT -->
    <div class="quiz-dc-screen quiz-dc-result" data-screen="result" hidden>
      <div class="quiz-dc-card quiz-dc-card--result">
        <div class="quiz-dc-eyebrow">Seu diagnóstico está pronto</div>
        <h2 class="quiz-dc-h2 quiz-dc-result-kit">Você precisa do<br><em></em></h2>
        <div class="quiz-dc-result-tagline"></div>
        <div class="quiz-dc-pills"></div>
        <p class="quiz-dc-result-desc"></p>
        <div class="quiz-dc-result-cards"></div>
        <div class="quiz-dc-tip"></div>
        <button type="button" class="quiz-dc-btn quiz-dc-cta"></button>
        <div class="quiz-dc-plan-note">Monte sua assinatura mensal com desconto →</div>
        <div class="quiz-dc-restart" role="button" tabindex="0">↻ Refazer o diagnóstico</div>
      </div>
    </div>

    <!-- PLAN / ASSINATURA -->
    <div class="quiz-dc-screen quiz-dc-plan" data-screen="plan" hidden>
      <div class="quiz-dc-plan-wrap">
        <div class="quiz-dc-back" role="button" tabindex="0">← Voltar ao resultado</div>
        <div class="quiz-dc-card quiz-dc-card--plan">
          <div class="quiz-dc-plan-hero">
            <div class="quiz-dc-eyebrow">Assinatura Mensal · Método CH</div>
            <h2 class="quiz-dc-h2">Faça a sua assinatura mensal e receba seu tratamento ideal <em>com desconto</em></h2>
            <div class="quiz-dc-plan-profile"></div>
            <p class="quiz-dc-plan-intro"></p>
          </div>
          <div class="quiz-dc-pricing-strip">
            <div class="quiz-dc-pricing-main">
              <div class="quiz-dc-pricing-label">Assinante paga</div>
              <div class="quiz-dc-pricing-val">
                R$ 719<span class="quiz-dc-pricing-freq">/mês</span>
                <span class="quiz-dc-pricing-old">R$ 816</span>
              </div>
            </div>
            <div class="quiz-dc-pricing-div"></div>
            <ul class="quiz-dc-pricing-perks">
              <li>Desconto exclusivo de assinante</li>
              <li>+8% no PIX · em até 12x</li>
              <li>Cancele quando quiser</li>
            </ul>
          </div>
          <div class="quiz-dc-plan-section">
            <div class="quiz-dc-plan-section-head">
              <h3 class="quiz-dc-plan-section-title">Seus 6 primeiros meses de tratamento</h3>
              <span class="quiz-dc-plan-section-sub">Um kit personalizado todo mês na sua casa</span>
            </div>
            <div class="quiz-dc-months"></div>
          </div>
          <div class="quiz-dc-box">
            <div class="quiz-dc-box-num">Mês&nbsp;7+<span>Box de manutenção</span></div>
            <div class="quiz-dc-box-div"></div>
            <div class="quiz-dc-box-body">
              <p class="quiz-dc-box-desc">A partir do 7º mês você passa a receber, todo mês, um box de manutenção montado para o seu perfil <strong class="quiz-dc-box-profile"></strong>:</p>
              <div class="quiz-dc-box-items"></div>
            </div>
          </div>
          <div class="quiz-dc-plan-cta">
            <a href="#" class="quiz-dc-btn quiz-dc-assin-btn" target="_self" rel="noopener">Assinar agora com desconto</a>
            <div class="quiz-dc-plan-cta-note">Frete grátis acima de R$400 · Cancele quando quiser</div>
          </div>
        </div>
      </div>
    </div>

  </main>
</div>

<script src="{{ 'quiz-capilar.js' | asset_url }}" defer></script>
<script>
  (function () {
    function boot() {
      var urls = {
        queda:        '{{ section.settings.url_queda | default: "/products/cronograma-capilar" }}',
        reconstrucao: '{{ section.settings.url_reconstrucao | default: "/products/kit-reconstrucao-diamond" }}',
        hidratacao:   '{{ section.settings.url_hidratacao | default: "/products/kit-hidratacao-diamond" }}',
        nutricao:     '{{ section.settings.url_nutricao | default: "/products/kit-nutricao-diamond" }}',
        cronograma:   '{{ section.settings.url_cronograma | default: "/products/cronograma-capilar" }}'
      };
      if (window.QuizCapilarInit) {
        window.QuizCapilarInit(document.getElementById('quiz-dc-{{ section.id }}'), { ctaUrls: urls });
      } else {
        document.addEventListener('DOMContentLoaded', function () {
          window.QuizCapilarInit && window.QuizCapilarInit(document.getElementById('quiz-dc-{{ section.id }}'), { ctaUrls: urls });
        });
      }
    }
    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', boot); }
    else { boot(); }
  })();
</script>

{% schema %}
{
  "name": "Quiz Diagnóstico Capilar",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Texto superior (eyebrow)", "default": "MEUCHB.COM.BR · MÉTODO CH" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Diagnóstico <em>Capilar</em>" },
    { "type": "text", "id": "subheading", "label": "Subtítulo", "default": "Responda 7 perguntas e descubra qual kit foi feito para o seu cabelo." },
    { "type": "header", "content": "Links dos kits (resultado do quiz)" },
    { "type": "url", "id": "url_queda",        "label": "Kit Anti-Queda — URL do produto" },
    { "type": "url", "id": "url_reconstrucao", "label": "Kit Reconstrução — URL do produto" },
    { "type": "url", "id": "url_hidratacao",   "label": "Kit Hidratação — URL do produto" },
    { "type": "url", "id": "url_nutricao",     "label": "Kit Nutrição — URL do produto" },
    { "type": "url", "id": "url_cronograma",   "label": "Kit Cronograma Completo — URL do produto" }
  ],
  "presets": [{ "name": "Quiz Diagnóstico Capilar" }]
}
{% endschema %}
