<script>
(function(){
  'use strict';
  function moneyBR(cents){
    return 'R$ '+new Intl.NumberFormat('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}).format(cents/100);
  }
  function numBR(cents){
    return new Intl.NumberFormat('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}).format(cents/100);
  }
  function initSub(sel){
    var dataEl=document.querySelector('.chb-sub-data');
    if(!dataEl) return;
    var sub     =parseInt(dataEl.dataset.sub);
    var full    =parseInt(dataEl.dataset.full);
    var subInst =parseInt(dataEl.dataset.subInst);
    var fullInst=parseInt(dataEl.dataset.fullInst);
    var subPix  =parseInt(dataEl.dataset.subPix);
    var fullPix =parseInt(dataEl.dataset.fullPix);
    var save    =parseInt(dataEl.dataset.save);

    sel.querySelectorAll('.chb-js-sub-price').forEach(function(e){e.textContent=moneyBR(sub);});
    sel.querySelectorAll('.chb-js-full-price').forEach(function(e){e.textContent=moneyBR(full);});
    sel.querySelectorAll('.chb-js-save').forEach(function(e){e.textContent='economize '+moneyBR(save);});

    function applyMode(mode){
      var isSub=mode==='sub';
      sel.querySelectorAll('.chb-sel-card').forEach(function(c){
        c.classList.toggle('chb-active',c.dataset.mode===mode);
      });
      // Main sale price
      var sp=document.querySelector('sale-price');
      if(sp) sp.textContent=moneyBR(isSub?sub:full);
      // Compare-at row visibility
      var cp=document.querySelector('compare-at-price');
      if(cp) cp.hidden=!isSub;
      // Discount badges
      document.querySelectorAll('.product-info__badge-list').forEach(function(b){
        b.style.visibility=isSub?'':'hidden';
      });
      // PIX economy
      var eco=document.querySelector('.discount-economy');
      if(eco) eco.textContent='Economize '+moneyBR(isSub?subPix:fullPix);
      // Installment value
      var iv=document.querySelector('.chb-inst-val');
      if(iv) iv.textContent=numBR(isSub?subInst:fullInst);
      // Hidden mode property for cart detection
      var modoInput=document.getElementById('chb-modo-{{ product_form_id }}');
      if(modoInput) modoInput.value=isSub?'sub':'unico';
    }

    sel.querySelectorAll('.chb-sel-card').forEach(function(card){
      card.addEventListener('click',function(){applyMode(card.dataset.mode);});
    });
    applyMode('sub');
  }

  function boot(){
    document.querySelectorAll('.chb-sub-selector').forEach(initSub);
  }
  if(document.readyState==='loading'){
    document.addEventListener('DOMContentLoaded',boot);
  } else {
    setTimeout(boot,0);
  }
})();
</script>
